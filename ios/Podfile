# Resolve react_native_pods.rb with node to allow for hoisting
# require Pod::Executable.execute_command('node', ['-p',
#   'require.resolve(
#     "react-native/scripts/react_native_pods.rb",
#     {paths: [process.argv[1]]},
#   )', __dir__]).strip

# RN 0.81.1 prebuilt Hermes iOS tarball may not contain hermes.framework dSYM.
# Build Hermes from source so Xcode archive includes the matching dSYM for upload.
ENV['RCT_BUILD_HERMES_FROM_SOURCE'] = 'true'

def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, min_ios_version_supported
prepare_react_native_project!

use_frameworks! :linkage => :static
# $RNFirebaseAsStaticFramework = true

setup_permissions([
  'AppTrackingTransparency',
  # 'Bluetooth',
  # 'Calendars',
  # 'CalendarsWriteOnly',
  'Camera',
  # 'Contacts',
  'FaceID',
  # 'LocationAccuracy',
  # 'LocationAlways',
  #  'LocationWhenInUse',
  'MediaLibrary',
  # 'Microphone',
  # 'Motion',
  # 'Notifications',
  'PhotoLibrary',
  'PhotoLibraryAddOnly',
  # 'Reminders',
  # 'Siri',
  # 'SpeechRecognition',
  # 'StoreKit',
])

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'qlts_app_2' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        if build_config.name == 'Release'
          build_config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
        end

        build_config.build_settings['ENABLE_MODULE_VERIFIER'] = 'NO'

        defs = build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
        defs = [defs] unless defs.is_a?(Array)
        defs << 'FMT_USE_CONSTEVAL=0' unless defs.include?('FMT_USE_CONSTEVAL=0')
        build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs

        cppflags = build_config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
        cppflags = [cppflags] unless cppflags.is_a?(Array)
        cppflags << '-DFMT_USE_CONSTEVAL=0' unless cppflags.include?('-DFMT_USE_CONSTEVAL=0')
        build_config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cppflags

        if target.name == 'glog'
          build_config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
          build_config.build_settings['MODULE_VERIFIER_SUPPORTED_LANGUAGE_STANDARDS'] = 'c++20'
        end
      end
    end

    fmt_base_header = File.join(installer.sandbox.root.to_s, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base_header)
      fmt_base = File.read(fmt_base_header)
      original = <<~'HEADER'
        // Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.
        #if !defined(__cpp_lib_is_constant_evaluated)
      HEADER
      patched = <<~'HEADER'
        // Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.
        #ifndef FMT_USE_CONSTEVAL
        #if !defined(__cpp_lib_is_constant_evaluated)
      HEADER
      footer_original = <<~'FOOTER'
        #else
        #  define FMT_USE_CONSTEVAL 0
        #endif
      FOOTER
      footer_patched = <<~'FOOTER'
        #else
        #  define FMT_USE_CONSTEVAL 0
        #endif
        #endif
      FOOTER

      if fmt_base.include?(original) && !fmt_base.include?('#ifndef FMT_USE_CONSTEVAL')
        fmt_base.sub!(original, patched)
        fmt_base.sub!(footer_original, footer_patched)
        FileUtils.chmod('u+w', fmt_base_header)
        File.write(fmt_base_header, fmt_base)
      end
    end

    installer.aggregate_targets.map(&:user_project).uniq.each do |project|
      app_target = project.targets.find { |target| target.name == 'qlts_app_2' }
      next unless app_target

      app_target.build_configurations.each do |build_config|
        build_config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      end

      phase_name = '[Hermes] Generate dSYM'
      phase = app_target.shell_script_build_phases.find { |build_phase| build_phase.name == phase_name }
      phase ||= app_target.new_shell_script_build_phase(phase_name)
      phase.shell_path = '/bin/sh'
      phase.shell_script = <<-'SCRIPT'
set -e

if [ "${CONFIGURATION}" != "Release" ]; then
  exit 0
fi

if [ "${ACTION}" != "install" ] && [ "${ACTION}" != "archive" ]; then
  exit 0
fi

HERMES_BINARY="${PODS_ROOT}/hermes-engine/build/iphoneos/API/hermes/hermes.framework/hermes"
HERMES_DSYM="${PODS_ROOT}/hermes-engine/build/iphoneos/API/hermes/hermes.framework.dSYM"
HERMES_PLIST="${PODS_ROOT}/hermes-engine/build/iphoneos/API/hermes/hermes.framework/Info.plist"
EMBEDDED_HERMES_PLIST="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/hermes.framework/Info.plist"

if [ ! -f "${HERMES_BINARY}" ]; then
  echo "Hermes binary not found at ${HERMES_BINARY}"
  exit 0
fi

echo "Regenerating Hermes dSYM..."
rm -rf "${HERMES_DSYM}"
xcrun dsymutil "${HERMES_BINARY}" -o "${HERMES_DSYM}"

if [ -f "${HERMES_PLIST}" ]; then
  /usr/libexec/PlistBuddy -c "Delete :MinimumOSVersion" "${HERMES_PLIST}" >/dev/null 2>&1 || true
  /usr/libexec/PlistBuddy -c "Add :MinimumOSVersion string ${IPHONEOS_DEPLOYMENT_TARGET}" "${HERMES_PLIST}"
fi

if [ -f "${EMBEDDED_HERMES_PLIST}" ]; then
  /usr/libexec/PlistBuddy -c "Delete :MinimumOSVersion" "${EMBEDDED_HERMES_PLIST}" >/dev/null 2>&1 || true
  /usr/libexec/PlistBuddy -c "Add :MinimumOSVersion string ${IPHONEOS_DEPLOYMENT_TARGET}" "${EMBEDDED_HERMES_PLIST}"
fi

if [ -d "${HERMES_DSYM}" ] && [ -n "${DWARF_DSYM_FOLDER_PATH}" ]; then
  mkdir -p "${DWARF_DSYM_FOLDER_PATH}"
  rm -rf "${DWARF_DSYM_FOLDER_PATH}/hermes.framework.dSYM"
  cp -R "${HERMES_DSYM}" "${DWARF_DSYM_FOLDER_PATH}/"
  echo "Copied Hermes dSYM to ${DWARF_DSYM_FOLDER_PATH}"
fi
      SCRIPT
      phase.show_env_vars_in_log = '0'
      project.save
    end
  end
end
